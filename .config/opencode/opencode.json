{
  "$schema": "https://opencode.ai/config.json",
  "agent": {
    "build": {
      "mode": "primary",
      "tools": {
        "write": true,
        "edit": true,
        "bash": true
      },
      "permission": {
        "edit": "ask",
        "webfetch": "ask",
        "bash": "ask"
      }
    },
    "explore": {
      "disable": true
    },
    "general": {
      "disable": true
    }
  },
  "permission": {
    "edit": "ask",
    "bash": {
      "git *": "allow",
      "ls *": "allow",
      "find *": "allow",
      "cat *": "allow",
      "grep *": "allow",
      "*": "ask"
    }
  },
  "plugin": [
    "opencode-openai-codex-auth",
    "oh-my-opencode-slim"
  ],
  "provider": {
    "amazon-bedrock": {
      "options": {
        "region": "eu-west-1",
        "profile": "production/developer"
      },
      "models": {
        "anthropic-claude-opus-4-5": {
          "name": "Anthropic Claude Opus 4.5 (Bedrock)",
          "id": "anthropic.claude-opus-4-5-20251101-v1:0"
        },
        "anthropic-claude-sonnet-4-6": {
          "name": "Anthropic Claude Sonnet 4.6 (Bedrock)",
          "id": "global.anthropic.claude-sonnet-4-6"
        },
        "anthropic-claude-haiku-4-5": {
          "name": "Anthropic Claude Haiku 4.5 (Bedrock)",
          "id": "global.anthropic.claude-haiku-4-5-20251001-v1:0"
        },
        "anthropic-claude-3-5-haiku": {
          "name": "Anthropic Claude 3.5 Haiku (Bedrock)",
          "id": "anthropic.claude-3-5-haiku-20240307-v1:0"
        }
      }
    },
    "openai": {
      "options": {
        "reasoningEffort": "medium",
        "reasoningSummary": "auto",
        "textVerbosity": "medium",
        "include": [
          "reasoning.encrypted_content"
        ],
        "store": false
      },
      "models": {
        "gpt-5.4": {
          "name": "GPT 5.4 (OAuth)",
          "variants": {
            "none": {
              "reasoningEffort": "none",
              "reasoningSummary": "auto",
              "textVerbosity": "medium"
            },
            "low": {
              "reasoningEffort": "low",
              "reasoningSummary": "auto",
              "textVerbosity": "medium"
            },
            "medium": {
              "reasoningEffort": "medium",
              "reasoningSummary": "auto",
              "textVerbosity": "medium"
            },
            "high": {
              "reasoningEffort": "high",
              "reasoningSummary": "detailed",
              "textVerbosity": "medium"
            },
            "xhigh": {
              "reasoningEffort": "xhigh",
              "reasoningSummary": "detailed",
              "textVerbosity": "medium"
            }
          }
        },
        "gpt-5.4-codex": {
          "name": "GPT 5.4 Codex (OAuth)",
          "variants": {
            "low": {
              "reasoningEffort": "low",
              "reasoningSummary": "auto",
              "textVerbosity": "medium"
            },
            "medium": {
              "reasoningEffort": "medium",
              "reasoningSummary": "auto",
              "textVerbosity": "medium"
            },
            "high": {
              "reasoningEffort": "high",
              "reasoningSummary": "detailed",
