// Niri config aligned with Hyprland keybinds
// See: https://niri-wm.github.io/niri/Configuration:-Introduction

// Start a bar (Waybar) + wallpaper
spawn-at-startup "waybar"
spawn-at-startup "hyprpaper"

// Input behavior
input {
    // Focus windows and outputs automatically when moving the mouse into them.
    focus-follows-mouse
}

// Outputs layout (external left, laptop right)
output "DP-1" {
    position x=0 y=0
}

output "eDP-1" {
    position x=2560 y=0
}

// Match Hyprland-like border styling
prefer-no-csd
layout {
    default-column-width { proportion 1.0; }

    focus-ring {
        width 2
        active-gradient from="#33ccffee" to="#00ff99ee" angle=45
        inactive-color "#595959aa"
    }

    border {
        width 2
        active-color "#33ccffee"
        inactive-color "#595959aa"
    }

    shadow {
        on
        softness 30
        spread 5
        offset x=0 y=5
        color "#1a1a1aee"
    }
}

// Window rules ported from Hyprland
window-rule {
    // Picture-in-Picture (Zen/Firefox/etc.)
    match title="^Picture-in-Picture$"
    open-floating true
    default-column-width { proportion 0.25; }
    default-window-height { proportion 0.25; }
    default-floating-position x=32 y=32 relative-to="bottom-right"
}

// Rounded corners (global)
window-rule {
    geometry-corner-radius 20
    clip-to-geometry true
}

window-rule {
    // Dolphin file manager
    match app-id=r#"^org\.kde\.dolphin$"#
    open-floating true
    default-column-width { proportion 0.5; }
    default-window-height { proportion 0.5; }
}

window-rule {
    // Blueman (Bluetooth Manager)
    match app-id=r#"blueman"#
    open-floating true
    default-column-width { proportion 0.5; }
    default-window-height { proportion 0.5; }
}

window-rule {
    // TUXEDO Control Center
    match title="^TUXEDO Control Center$"
    open-floating true
    default-column-width { proportion 0.5; }
    default-window-height { proportion 0.5; }
}

binds {
    // Apps & session
    Mod+Return { spawn "ghostty"; }
    Mod+E { spawn "dolphin"; }
    Mod+Space { spawn "rofi" "-show" "drun"; }
    Mod+Ctrl+Alt+Shift+Q { spawn "wlogout"; }

    // Window controls
    Mod+Q repeat=false { close-window; }
    Mod+M repeat=false { quit; }
    Mod+V { toggle-window-floating; }
    Mod+F { fullscreen-window; }
    Mod+Ctrl+Alt+Shift+F { fullscreen-window; }

    // Workspace navigation
    Mod+Tab { focus-workspace-previous; }
    Mod+Ctrl+Alt+Shift+Tab { focus-workspace-previous; }
    Alt+Shift+Tab { spawn "~/.config/scripts/niri-move-workspace-to-next-monitor.sh"; }

    // Keyboard layout cycling (ensure multiple layouts configured)
    Alt+Space { switch-layout "next"; }

    // Focus movement (arrows)
    Mod+Left  { focus-column-left; }
    Mod+Right { focus-column-right; }
    Mod+Up    { focus-window-up; }
    Mod+Down  { focus-window-down; }

    // Focus movement (vim keys)
    Mod+H { focus-column-left; }
    Mod+L { focus-column-right; }
    Mod+K { focus-window-up; }
    Mod+J { focus-window-down; }

    // Focus movement (hyper for Corne)
    Mod+Ctrl+Alt+Shift+H { focus-column-left; }
    Mod+Ctrl+Alt+Shift+L { focus-column-right; }
    Mod+Ctrl+Alt+Shift+K { focus-window-up; }
    Mod+Ctrl+Alt+Shift+J { focus-window-down; }

    // Workspaces (1-10)
    Mod+1 { focus-workspace 1; }
    Mod+2 { focus-workspace 2; }
    Mod+3 { focus-workspace 3; }
    Mod+4 { focus-workspace 4; }
    Mod+5 { focus-workspace 5; }
    Mod+6 { focus-workspace 6; }
    Mod+7 { focus-workspace 7; }
    Mod+8 { focus-workspace 8; }
    Mod+9 { focus-workspace 9; }
    Mod+0 { focus-workspace 10; }

    // Repeat with hyper for Corne
    Mod+Ctrl+Alt+Shift+1 { focus-workspace 1; }
    Mod+Ctrl+Alt+Shift+2 { focus-workspace 2; }
    Mod+Ctrl+Alt+Shift+3 { focus-workspace 3; }
    Mod+Ctrl+Alt+Shift+4 { focus-workspace 4; }
    Mod+Ctrl+Alt+Shift+5 { focus-workspace 5; }
    Mod+Ctrl+Alt+Shift+6 { focus-workspace 6; }
    Mod+Ctrl+Alt+Shift+7 { focus-workspace 7; }
    Mod+Ctrl+Alt+Shift+8 { focus-workspace 8; }
    Mod+Ctrl+Alt+Shift+9 { focus-workspace 9; }
    Mod+Ctrl+Alt+Shift+0 { focus-workspace 10; }

    // Move focused window to workspace (1-10)
    Mod+Shift+1 { move-window-to-workspace 1; }
    Mod+Shift+2 { move-window-to-workspace 2; }
    Mod+Shift+3 { move-window-to-workspace 3; }
    Mod+Shift+4 { move-window-to-workspace 4; }
    Mod+Shift+5 { move-window-to-workspace 5; }
    Mod+Shift+6 { move-window-to-workspace 6; }
    Mod+Shift+7 { move-window-to-workspace 7; }
    Mod+Shift+8 { move-window-to-workspace 8; }
    Mod+Shift+9 { move-window-to-workspace 9; }
    Mod+Shift+0 { move-window-to-workspace 10; }

    // Repeat with Alt+Shift (Corne)
    Alt+Shift+1 { move-window-to-workspace 1; }
    Alt+Shift+2 { move-window-to-workspace 2; }
    Alt+Shift+3 { move-window-to-workspace 3; }
    Alt+Shift+4 { move-window-to-workspace 4; }
    Alt+Shift+5 { move-window-to-workspace 5; }
    Alt+Shift+6 { move-window-to-workspace 6; }
    Alt+Shift+7 { move-window-to-workspace 7; }
    Alt+Shift+8 { move-window-to-workspace 8; }
    Alt+Shift+9 { move-window-to-workspace 9; }
    Alt+Shift+0 { move-window-to-workspace 10; }

    // Scroll through workspaces
    Mod+WheelScrollDown cooldown-ms=150 { focus-workspace-down; }
    Mod+WheelScrollUp cooldown-ms=150 { focus-workspace-up; }

    // Media keys
    XF86AudioRaiseVolume allow-when-locked=true { spawn-sh "wpctl set-volume -l 1 @DEFAULT_AUDIO_SINK@ 5%+"; }
    XF86AudioLowerVolume allow-when-locked=true { spawn-sh "wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%-"; }
    XF86AudioMute        allow-when-locked=true { spawn-sh "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle"; }
    XF86AudioMicMute     allow-when-locked=true { spawn-sh "wpctl set-mute @DEFAULT_AUDIO_SOURCE@ toggle"; }

    XF86MonBrightnessUp   allow-when-locked=true { spawn-sh "brightnessctl -e4 -n2 set 5%+"; }
    XF86MonBrightnessDown allow-when-locked=true { spawn-sh "brightnessctl -e4 -n2 set 5%-"; }

    XF86AudioNext allow-when-locked=true { spawn-sh "playerctl next"; }
    XF86AudioPause allow-when-locked=true { spawn-sh "playerctl play-pause"; }
    XF86AudioPlay allow-when-locked=true { spawn-sh "playerctl play-pause"; }
    XF86AudioPrev allow-when-locked=true { spawn-sh "playerctl previous"; }
}
